    {
      "name": "4. Verificacion Pagos y Entregas",
      "item": [
        {
          "name": "Listar pagos",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const payments = pm.response.json();",
                  "const orderId = Number(pm.collectionVariables.get('orderId'));",
                  "const payment = Array.isArray(payments) ? payments.find(p => p.orderId === orderId) : null;",
                  "",
                  "pm.test('Existe pago para el orderId probado', function () {",
                  "  pm.expect(payment, 'No se encontro pago para el orderId actual').to.exist;",
                  "});",
                  "",
                  "if (payment) {",
                  "  pm.test('Pago en estado PAID al final del flujo', function () {",
                  "    pm.expect(payment.status).to.eql('PAID');",
                  "  });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/payments",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "payments"
              ]
            }
          }
        },
        {
          "name": "Listar entregas",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const deliveries = pm.response.json();",
                  "const orderId = Number(pm.collectionVariables.get('orderId'));",
                  "const delivery = Array.isArray(deliveries) ? deliveries.find(d => d.orderId === orderId) : null;",
                  "",
                  "pm.test('Existe entrega para el orderId probado', function () {",
                  "  pm.expect(delivery, 'No se encontro entrega para el orderId actual').to.exist;",
                  "});",
                  "",
                  "if (delivery) {",
                  "  pm.test('Entrega en estado FINALIZED al final del flujo', function () {",
                  "    pm.expect(delivery.status).to.eql('FINALIZED');",
                  "  });",
                  "}"
                ]
              }
            }
