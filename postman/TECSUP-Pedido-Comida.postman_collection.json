    {
      "name": "3. Flujo Pedido",
      "item": [
        {
          "name": "Crear pedido",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const data = pm.response.json();",
                  "pm.test('Pedido creado con id', function () {",
                  "  pm.expect(data.id).to.be.ok;",
                  "});",
                  "pm.test('Estado inicial CREATED', function () {",
                  "  pm.expect(data.status).to.eql('CREATED');",
                  "});",
                  "pm.test('Pedido devuelve items', function () {",
                  "  pm.expect(data.items).to.be.an('array').and.not.empty;",
                  "});",
                  "pm.test('Total calculado mayor a 0', function () {",
                  "  pm.expect(Number(data.totalAmount)).to.be.greaterThan(0);",
                  "});",
                  "",
                  "pm.collectionVariables.set('orderId', String(data.id));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": {{userId}},\n  \"items\": [\n    { \"productId\": {{productId1}}, \"quantity\": {{quantity1}} },\n    { \"productId\": {{productId2}}, \"quantity\": {{quantity2}} }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/orders",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "orders"
              ]
            },
            "description": "Guarda el id del pedido en {{orderId}}. El total se calcula automaticamente segun productId + quantity."
          }
        },
